# .env.example — Template for local development
# Copy this file to .env and fill in your real values.
# NEVER commit .env or service_account.json to the repository.
#
# In GitHub Actions, these are stored as GitHub Secrets (Settings → Secrets).

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your sheet's URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your downloaded service account JSON key file (local only)
# In GitHub Actions this is set automatically by the workflow decode step.
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
